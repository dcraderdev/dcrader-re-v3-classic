---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const listings = [
  {
    address: '1420 Buckingham Dr',
    city: 'Naperville',
    price: '$589,000',
    beds: 4,
    baths: '3',
    sqft: '2,480',
    image: 'https://images.unsplash.com/photo-1568605114967-8130f3a36994?w=900&q=85&fit=crop&auto=format',
    rotate: '-rotate-1',
  },
  {
    address: '847 Whittier Ave',
    city: 'Naperville',
    price: '$724,000',
    beds: 5,
    baths: '3.5',
    sqft: '3,100',
    image: 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=900&q=85&fit=crop&auto=format',
    rotate: 'rotate-1',
  },
  {
    address: '2215 Westglen Dr',
    city: 'Wheaton',
    price: '$468,000',
    beds: 3,
    baths: '2',
    sqft: '1,840',
    image: 'https://images.unsplash.com/photo-1570129477492-45c003edd2be?w=900&q=85&fit=crop&auto=format',
    rotate: 'rotate-0',
  },
  {
    address: '3341 Fairview Ave',
    city: 'Downers Grove',
    price: '$392,000',
    beds: 3,
    baths: '2',
    sqft: '1,620',
    image: 'https://images.unsplash.com/photo-1523217582562-09d0def993a6?w=900&q=85&fit=crop&auto=format',
    rotate: 'rotate-1',
  },
  {
    address: '612 S Washington St',
    city: 'Naperville',
    price: '$845,000',
    beds: 5,
    baths: '4',
    sqft: '3,600',
    image: 'https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=900&q=85&fit=crop&auto=format',
    rotate: '-rotate-1',
  },
  {
    address: '1887 Thornberry Ln',
    city: 'Lisle',
    price: '$312,000',
    beds: 3,
    baths: '2',
    sqft: '1,400',
    image: 'https://images.unsplash.com/photo-1576941089067-2de3c901e126?w=900&q=85&fit=crop&auto=format',
    rotate: 'rotate-0',
  },
];

const testimonials = [
  {
    quote: 'Mike and Kathy treated us like family from day one. They found us exactly what we were looking for in Naperville and never made us feel rushed. 32 years of experience shows in every conversation.',
    name: 'Brandon & Lisa Crawford',
    location: 'Bought in Naperville',
    photo: 'https://images.unsplash.com/photo-1499952127939-9bbf5af6c51c?w=200&q=85&fit=crop&auto=format',
    rotate: '-rotate-2',
  },
  {
    quote: "We've sold three homes with the Petersens. Every single time, they've exceeded expectations. Kathy's staging advice added $40,000 to our sale price.",
    name: 'Robert Janssen',
    location: 'Sold in Wheaton',
    photo: 'https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?w=200&q=85&fit=crop&auto=format',
    rotate: 'rotate-1',
  },
  {
    quote: "First-time buyers don't need a salesperson. They need a teacher. Mike sat with us for three hours explaining everything. We never felt pressured.",
    name: 'Aisha & Deon Washington',
    location: 'Bought in Downers Grove',
    photo: 'https://images.unsplash.com/photo-1542909168-82c3e7fdca5c?w=200&q=85&fit=crop&auto=format',
    rotate: '-rotate-1',
  },
];
---

<Layout>
  <!-- ============================================================
       1. NAV — CENTERED MASTHEAD
  ============================================================ -->
  <nav id="navbar" class="fixed top-0 left-0 right-0 z-50 bg-white border-b-2 border-navy shadow-sm">
    <!-- Top bar -->
    <div class="text-center py-1 px-4">
      <span class="font-sans text-xs tracking-widest uppercase text-navy/60">The Petersen Group</span>
    </div>
    <!-- Gold rule -->
    <div class="h-px bg-gold mx-6"></div>
    <!-- Masthead -->
    <div class="text-center py-2 px-4">
      <a href="/" class="font-serif text-2xl md:text-3xl font-bold text-navy leading-tight hover:text-navy-mid transition-colors">
        The Petersen Group
      </a>
      <p class="font-sans text-xs italic text-navy/60 mt-0.5">
        Mike &amp; Kathy Petersen &nbsp;&middot;&nbsp; Naperville Real Estate Since 1992
      </p>
    </div>
    <!-- Gold rule -->
    <div class="h-px bg-gold mx-6"></div>
    <!-- Nav links (desktop) -->
    <div class="hidden md:flex items-center justify-center gap-6 py-2 px-4">
      <a href="#listings" class="font-sans text-sm text-navy hover:text-gold transition-colors">Properties</a>
      <a href="#neighborhoods" class="font-sans text-sm text-navy hover:text-gold transition-colors">Our Areas</a>
      <a href="#about" class="font-sans text-sm text-navy hover:text-gold transition-colors">About Us</a>
      <a href="#testimonials" class="font-sans text-sm text-navy hover:text-gold transition-colors">Sold</a>
      <a href="#contact" class="font-sans text-sm text-navy hover:text-gold transition-colors">Contact</a>
      <a
        href="tel:6305550274"
        class="ml-4 bg-navy text-white font-sans text-sm font-semibold px-4 py-1.5 rounded-full hover:bg-navy-mid transition-colors"
      >
        (630) 555-0274
      </a>
    </div>
    <!-- Mobile hamburger -->
    <div class="md:hidden flex items-center justify-between px-4 py-2">
      <span class="font-sans text-sm text-navy/60">Menu</span>
      <button
        id="mobile-menu-btn"
        class="text-navy focus:outline-none"
        aria-label="Open menu"
        aria-expanded="false"
      >
        <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile overlay menu -->
  <div
    id="mobile-menu"
    class="fixed inset-0 z-40 bg-beige flex flex-col items-center justify-center gap-8 hidden"
  >
    <a href="#listings" class="mobile-nav-link font-serif text-2xl text-navy">Properties</a>
    <a href="#neighborhoods" class="mobile-nav-link font-serif text-2xl text-navy">Our Areas</a>
    <a href="#about" class="mobile-nav-link font-serif text-2xl text-navy">About Us</a>
    <a href="#testimonials" class="mobile-nav-link font-serif text-2xl text-navy">Sold</a>
    <a href="#contact" class="mobile-nav-link font-serif text-2xl text-navy">Contact</a>
    <a
      href="tel:6305550274"
      class="bg-navy text-white font-sans text-lg font-semibold px-8 py-3 rounded-full"
    >
      (630) 555-0274
    </a>
  </div>

  <!-- ============================================================
       2. HERO — WARM FAMILY TEAM PHOTO
  ============================================================ -->
  <section class="pt-36 md:pt-40 pb-16 md:pb-24 bg-beige overflow-hidden">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">

        <!-- Left: Text -->
        <div class="flex-1 lg:w-[55%] animate-on-scroll">
          <p class="font-sans text-xs tracking-widest uppercase text-navy font-semibold mb-3">
            Naperville's Most Trusted Real Estate Team
          </p>
          <h1
            class="font-serif font-bold text-navy leading-tight mb-4"
            style="font-size: clamp(2.5rem, 6vw, 5rem);"
          >
            The Petersen<br />Group
          </h1>
          <p class="font-serif italic text-gold text-xl md:text-2xl mb-5">
            Mike &amp; Kathy Petersen
          </p>
          <p class="font-sans text-navy/70 text-lg leading-relaxed mb-8">
            Naperville experts since 1992. Over 1,200 families helped find home
            in the western suburbs — and we still answer our own phones.
          </p>
          <!-- CTAs -->
          <div class="flex flex-wrap gap-4 mb-10">
            <a
              href="#listings"
              class="bg-navy text-white font-sans font-semibold px-8 py-3 rounded hover:bg-navy-mid transition-colors"
            >
              See Our Homes
            </a>
            <a
              href="#contact"
              class="border-2 border-gold text-navy font-sans font-semibold px-8 py-3 rounded hover:bg-gold/10 transition-colors"
            >
              Free Home Value
            </a>
          </div>
          <!-- Achievement row -->
          <div class="flex flex-wrap gap-x-6 gap-y-2">
            {['1,200+ Families', '32 Years', '#1 Naperville Team', '4.9★ Rating'].map((item) => (
              <span class="font-sans text-sm font-semibold text-navy border-l-2 border-gold pl-3">
                {item}
              </span>
            ))}
          </div>
        </div>

        <!-- Right: Decorative scrapbook frame -->
        <div class="flex-shrink-0 lg:w-[45%] flex flex-col items-center animate-on-scroll" style="animation-delay: 0.2s;">
          <div class="relative" style="max-width: 420px; width: 100%;">
            <!-- Outer shadow offset (scrapbook depth effect) -->
            <div class="absolute inset-0 bg-navy-dark translate-x-3 translate-y-3 rounded-sm"></div>
            <!-- Frame -->
            <div
              class="relative border-4 border-navy bg-cream overflow-hidden rounded-sm"
              style="box-shadow: inset 0 0 0 6px #FDFAF5, inset 0 0 0 8px #1B3A5C;"
            >
              <!-- Inner cream mat border -->
              <div class="p-2 bg-cream">
                <div class="relative overflow-hidden" style="padding-top: 75%;">
                  <img
                    src="https://images.unsplash.com/photo-1560184897-ae75f418493e?w=900&q=85&fit=crop&auto=format"
                    alt="Mike and Kathy Petersen, Principal Brokers"
                    class="absolute inset-0 w-full h-full object-cover scale-105"
                    loading="eager"
                  />
                  <!-- Since 1992 ribbon -->
                  <div
                    class="absolute overflow-hidden"
                    style="bottom: 0; right: 0; width: 120px; height: 120px;"
                  >
                    <div
                      class="absolute bg-brick text-white font-sans font-bold text-xs text-center"
                      style="
                        bottom: 20px;
                        right: -32px;
                        width: 140px;
                        padding: 5px 0;
                        transform: rotate(-45deg);
                        transform-origin: center;
                      "
                    >
                      Since 1992
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <!-- Caption -->
          <p class="font-serif italic text-navy/60 text-sm mt-4 text-center">
            Mike &amp; Kathy Petersen, Principal Brokers
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================================
       3. WHY THE PETERSEN GROUP
  ============================================================ -->
  <section class="py-16 md:py-24 bg-beige-dark">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-12 animate-on-scroll">
        <h2 class="font-serif font-bold text-navy text-3xl md:text-4xl mb-3">
          Why Naperville Families Choose Us
        </h2>
        <p class="font-sans italic text-navy/60 text-lg">
          32 years. 1,200+ families. One promise: we work harder for you.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Feature 1 -->
        <div class="bg-beige border-t-4 border-navy p-8 animate-on-scroll" style="animation-delay: 0.1s;">
          <div class="mb-5">
            <svg class="w-10 h-10 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418"/>
            </svg>
          </div>
          <h3 class="font-serif font-bold text-navy text-xl mb-3">Local Experts Since 1992</h3>
          <p class="font-sans text-navy/70 leading-relaxed">
            We know every block, every neighborhood, every school district. When you work with us,
            you get 32 years of Naperville knowledge in every conversation.
          </p>
        </div>

        <!-- Feature 2 -->
        <div class="bg-beige border-t-4 border-navy p-8 animate-on-scroll" style="animation-delay: 0.2s;">
          <div class="mb-5">
            <svg class="w-10 h-10 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z"/>
            </svg>
          </div>
          <h3 class="font-serif font-bold text-navy text-xl mb-3">Proven Track Record</h3>
          <p class="font-sans text-navy/70 leading-relaxed">
            97% of our listings sell above asking price within 30 days. Not because of luck —
            because of preparation, pricing strategy, and 32 years of negotiation experience.
          </p>
        </div>

        <!-- Feature 3 -->
        <div class="bg-beige border-t-4 border-navy p-8 animate-on-scroll" style="animation-delay: 0.3s;">
          <div class="mb-5">
            <svg class="w-10 h-10 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.182 15.182a4.5 4.5 0 0 1-6.364 0M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0ZM9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75Zm-.375 0h.008v.015h-.008V9.75Zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75Zm-.375 0h.008v.015h-.008V9.75Z"/>
            </svg>
          </div>
          <h3 class="font-serif font-bold text-navy text-xl mb-3">Family First Service</h3>
          <p class="font-sans text-navy/70 leading-relaxed">
            We return every call within 2 hours. Your timeline is our timeline.
            You're not a commission — you're a neighbor we're proud to help.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       4. FEATURED LISTINGS — SCRAPBOOK CARDS
  ============================================================ -->
  <section id="listings" class="py-16 md:py-24 bg-white">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-12 animate-on-scroll">
        <p class="font-sans text-xs tracking-widest uppercase text-gold font-semibold mb-2">
          Just Listed
        </p>
        <h2 class="font-serif font-bold text-navy text-3xl md:text-4xl">
          Our Current Listings
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {listings.map((listing, i) => (
          <div
            class={`relative bg-white border-2 border-navy overflow-visible animate-on-scroll scrapbook-card cursor-pointer group`}
            style={`animation-delay: ${i * 0.1}s;`}
          >
            <!-- Photo with rotation -->
            <div class={`overflow-hidden ${listing.rotate}`} style="transform-origin: center;">
              <div class="relative overflow-hidden" style="padding-top: 66%;">
                <img
                  src={listing.image}
                  alt={listing.address}
                  class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
              </div>
            </div>

            <!-- Card body -->
            <div class="p-5">
              <p class="font-sans text-xs tracking-widest uppercase text-gold font-semibold mb-1">
                {listing.city}, IL
              </p>
              <h3 class="font-serif font-bold text-navy text-lg leading-tight mb-1">
                {listing.address}
              </h3>
              <p class="font-serif font-bold text-navy text-2xl mb-3">
                {listing.price}
              </p>
              <p class="font-sans text-navy/60 text-sm mb-4">
                {listing.beds} bd &nbsp;&bull;&nbsp; {listing.baths} ba &nbsp;&bull;&nbsp; {listing.sqft} sf
              </p>
              <div class="flex items-center justify-between">
                <span class="font-sans text-xs font-semibold text-brick border border-brick px-3 py-1 rounded-full uppercase tracking-wide">
                  Active Listing
                </span>
                <span class="font-sans text-sm text-gold font-semibold group-hover:underline">
                  View Details →
                </span>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="text-center mt-12 animate-on-scroll">
        <a
          href="#contact"
          class="inline-block bg-navy text-white font-sans font-semibold px-10 py-3 rounded hover:bg-navy-mid transition-colors"
        >
          See All Our Listings
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       5. OUR NEIGHBORHOODS — ILLUSTRATED MAP SECTION
  ============================================================ -->
  <section id="neighborhoods" class="py-16 md:py-24 bg-beige">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-12 animate-on-scroll">
        <h2 class="font-serif font-bold text-navy text-3xl md:text-4xl mb-3">
          We Know Every Corner of Naperville
        </h2>
        <p class="font-sans italic text-navy/60 text-lg">
          Six communities. One team. Decades of local knowledge.
        </p>
      </div>

      <div class="flex flex-col lg:flex-row gap-10 items-start">

        <!-- Left: SVG map -->
        <div class="flex-shrink-0 lg:w-[48%] animate-on-scroll">
          <div class="border-2 border-navy/20 bg-cream p-4 shadow-md">
            <svg
              viewBox="0 0 400 360"
              xmlns="http://www.w3.org/2000/svg"
              class="w-full"
              aria-label="Map of Naperville and western suburbs"
            >
              <!-- Background -->
              <rect width="400" height="360" fill="#FDFAF5"/>

              <!-- Water (DuPage River, rough) -->
              <path d="M160 340 Q170 300 165 260 Q160 220 168 180 Q175 150 170 120" stroke="#A8C4D8" stroke-width="3" fill="none" stroke-dasharray="4 2"/>

              <!-- City area shapes (representational polygons) -->
              <!-- Aurora (west) -->
              <polygon points="30,180 90,150 100,200 95,250 40,260" fill="#EAE3D6" stroke="#1B3A5C" stroke-width="1.5" opacity="0.7"/>
              <!-- Naperville (center) -->
              <polygon points="110,130 190,120 210,160 220,220 200,260 150,270 120,240 100,190" fill="#D9CEBD" stroke="#1B3A5C" stroke-width="2" opacity="0.85"/>
              <!-- Wheaton (north) -->
              <polygon points="170,60 260,50 270,100 240,130 190,120 160,100" fill="#EAE3D6" stroke="#1B3A5C" stroke-width="1.5" opacity="0.7"/>
              <!-- Downers Grove (east) -->
              <polygon points="250,130 330,120 340,180 300,210 240,200 220,160" fill="#EAE3D6" stroke="#1B3A5C" stroke-width="1.5" opacity="0.7"/>
              <!-- Lisle (southeast) -->
              <polygon points="220,220 290,210 310,260 270,290 210,270" fill="#EAE3D6" stroke="#1B3A5C" stroke-width="1.5" opacity="0.7"/>
              <!-- Bolingbrook (southwest) -->
              <polygon points="100,260 160,260 170,310 130,340 75,320 80,280" fill="#EAE3D6" stroke="#1B3A5C" stroke-width="1.5" opacity="0.7"/>

              <!-- Roads (simplified) -->
              <line x1="0" y1="190" x2="400" y2="190" stroke="#B8A898" stroke-width="1" stroke-dasharray="6 3"/>
              <line x1="195" y1="0" x2="195" y2="360" stroke="#B8A898" stroke-width="1" stroke-dasharray="6 3"/>

              <!-- City pins: circle + dot -->
              <!-- Naperville (center) -->
              <circle cx="162" cy="195" r="10" fill="#1B3A5C" opacity="0.15"/>
              <circle cx="162" cy="195" r="5" fill="#1B3A5C"/>
              <circle cx="162" cy="195" r="2" fill="#C49A3C"/>
              <text x="175" y="192" font-family="Georgia, serif" font-size="11" font-weight="bold" fill="#1B3A5C">Naperville</text>
              <!-- Badge -->
              <circle cx="238" cy="183" r="9" fill="#1B3A5C"/>
              <text x="238" y="187" font-family="Georgia, serif" font-size="9" fill="white" text-anchor="middle">12</text>

              <!-- Wheaton (north) -->
              <circle cx="215" cy="90" r="7" fill="#1B3A5C" opacity="0.15"/>
              <circle cx="215" cy="90" r="4" fill="#1B3A5C"/>
              <circle cx="215" cy="90" r="1.5" fill="#C49A3C"/>
              <text x="225" y="87" font-family="Georgia, serif" font-size="10" fill="#1B3A5C">Wheaton</text>
              <circle cx="270" cy="80" r="8" fill="#1B3A5C"/>
              <text x="270" y="84" font-family="Georgia, serif" font-size="9" fill="white" text-anchor="middle">4</text>

              <!-- Downers Grove (east) -->
              <circle cx="285" cy="165" r="7" fill="#1B3A5C" opacity="0.15"/>
              <circle cx="285" cy="165" r="4" fill="#1B3A5C"/>
              <circle cx="285" cy="165" r="1.5" fill="#C49A3C"/>
              <text x="295" y="163" font-family="Georgia, serif" font-size="10" fill="#1B3A5C">Downers Grove</text>
              <circle cx="373" cy="154" r="8" fill="#1B3A5C"/>
              <text x="373" y="158" font-family="Georgia, serif" font-size="9" fill="white" text-anchor="middle">3</text>

              <!-- Lisle (southeast) -->
              <circle cx="255" cy="248" r="7" fill="#1B3A5C" opacity="0.15"/>
              <circle cx="255" cy="248" r="4" fill="#1B3A5C"/>
              <circle cx="255" cy="248" r="1.5" fill="#C49A3C"/>
              <text x="265" y="246" font-family="Georgia, serif" font-size="10" fill="#1B3A5C">Lisle</text>
              <circle cx="295" cy="237" r="8" fill="#1B3A5C"/>
