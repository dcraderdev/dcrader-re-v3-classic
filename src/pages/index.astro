---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const listings = [
  {
    address: '1847 Bauer Road',
    city: 'Naperville',
    price: '$749,000',
    beds: 4,
    baths: '3',
    image: 'https://images.unsplash.com/photo-1568605114967-8130f3a36994?w=600&q=85',
    rotate: '-0.5deg',
    status: 'ACTIVE',
  },
  {
    address: '432 Whispering Pines',
    city: 'Wheaton',
    price: '$599,000',
    beds: 3,
    baths: '2',
    image: 'https://images.unsplash.com/photo-1570129477492-45c003edd2be?w=600&q=85',
    rotate: '0.5deg',
    status: 'ACTIVE',
  },
  {
    address: '2241 Briarcliff Dr',
    city: 'Downers Grove',
    price: '$849,000',
    beds: 5,
    baths: '3.5',
    image: 'https://images.unsplash.com/photo-1523217582562-09d0def993a6?w=600&q=85',
    rotate: '-0.5deg',
    status: 'ACTIVE',
  },
  {
    address: '715 Lincoln Ave',
    city: 'Naperville',
    price: '$529,000',
    beds: 3,
    baths: '2',
    image: 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=600&q=85',
    rotate: '0.5deg',
    status: 'ACTIVE',
  },
];

const teamMembers = [
  {
    name: 'Mike Petersen',
    role: 'Principal Broker',
    img: 'https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?w=400&q=85',
    zIndex: 10,
    rotate: '-2deg',
    left: '0px',
    top: '0px',
  },
  {
    name: 'Kathy Petersen',
    role: 'Principal Broker',
    img: 'https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=400&q=85',
    zIndex: 20,
    rotate: '1.5deg',
    left: '80px',
    top: '-20px',
  },
  {
    name: 'Sarah Petersen',
    role: 'Buyer\'s Agent',
    img: 'https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=400&q=85',
    zIndex: 30,
    rotate: '-1deg',
    left: '160px',
    top: '10px',
  },
  {
    name: 'Tom Petersen',
    role: 'Listing Specialist',
    img: 'https://images.unsplash.com/photo-1463453091185-61582044d556?w=400&q=85',
    zIndex: 40,
    rotate: '2deg',
    left: '240px',
    top: '-10px',
  },
];

const testimonials = [
  {
    quote: 'Mike and Kathy have been our neighbors for 20 years — when it was time to sell, there was no one else to call.',
    name: 'Robert & Susan T.',
    location: 'Bought in Naperville, 2024',
  },
  {
    quote: 'The whole family was involved. It felt like working with people who genuinely cared about us landing in the right home.',
    name: 'The Nguyen Family',
    location: 'Sold in Wheaton, 2024',
  },
  {
    quote: '32 years of knowing this market means they saw our home\'s value that Zillow never could.',
    name: 'David M.',
    location: 'Bought in Downers Grove, 2023',
  },
];

const neighborhoods = [
  { name: 'Naperville', photo: 'https://images.unsplash.com/photo-1570129477492-45c003edd2be?w=600&q=85', listings: 12 },
  { name: 'Wheaton', photo: 'https://images.unsplash.com/photo-1568605114967-8130f3a36994?w=600&q=85', listings: 4 },
  { name: 'Downers Grove', photo: 'https://images.unsplash.com/photo-1523217582562-09d0def993a6?w=600&q=85', listings: 3 },
  { name: 'Lisle', photo: 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=600&q=85', listings: 2 },
];
---

<Layout title="The Petersen Group | Naperville Real Estate Since 1992">

  <!-- ============================================================
       1. NAV — CENTERED FAMILY MASTHEAD
  ============================================================ -->
  <nav class="bg-white border-b-2 border-navy sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4">

      <!-- Centered masthead -->
      <div class="text-center py-3 border-b border-beige-dark">
        <a href="/" class="font-serif font-bold text-navy text-2xl md:text-3xl tracking-tight">
          The Petersen Group
        </a>
        <p class="font-sans text-xs tracking-[0.2em] uppercase text-navy/50 mt-0.5">
          Naperville &nbsp;&middot;&nbsp; Wheaton &nbsp;&middot;&nbsp; Downers Grove &nbsp;&middot;&nbsp; Lisle
        </p>
      </div>

      <!-- Nav links row -->
      <div class="hidden md:flex items-center justify-center relative py-2 gap-8">
        <a href="#listings" class="font-sans text-sm text-navy hover:text-gold transition-colors tracking-wide">Listings</a>
        <a href="#neighborhoods" class="font-sans text-sm text-navy hover:text-gold transition-colors tracking-wide">Areas</a>
        <a href="#about" class="font-sans text-sm text-navy hover:text-gold transition-colors tracking-wide">About</a>
        <a href="#testimonials" class="font-sans text-sm text-navy hover:text-gold transition-colors tracking-wide">Sold</a>
        <a href="#contact" class="font-sans text-sm text-navy hover:text-gold transition-colors tracking-wide">Contact</a>
        <!-- Phone in corner -->
        <div class="absolute right-0 top-1/2 -translate-y-1/2 flex items-center gap-3">
          <span class="font-sans text-xs text-navy/60">(630) 555-0274</span>
          <a href="tel:6305550274" class="bg-navy text-white font-sans text-xs font-bold px-4 py-2 hover:bg-navy-mid transition-colors tracking-wide">
            Call Us
          </a>
        </div>
      </div>

      <!-- Mobile menu row -->
      <div class="md:hidden flex items-center justify-between py-2">
        <a href="tel:6305550274" class="font-sans text-sm text-navy font-semibold">(630) 555-0274</a>
        <button id="mobile-btn" class="text-navy focus:outline-none">
          <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <!-- Mobile drawer -->
  <div id="mobile-menu" class="hidden fixed inset-0 bg-beige z-40 flex flex-col items-center justify-center gap-8">
    <a href="#listings" class="mobile-link font-serif text-3xl text-navy">Listings</a>
    <a href="#neighborhoods" class="mobile-link font-serif text-3xl text-navy">Areas</a>
    <a href="#about" class="mobile-link font-serif text-3xl text-navy">About</a>
    <a href="#testimonials" class="mobile-link font-serif text-3xl text-navy">Sold</a>
    <a href="#contact" class="mobile-link font-serif text-3xl text-navy">Contact</a>
  </div>

  <!-- ============================================================
       2. HERO — WARM BEIGE, SCRAPBOOK FRAMED PHOTO
  ============================================================ -->
  <section class="bg-beige pt-10 pb-16 overflow-hidden">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">

      <!-- Decorative top rule -->
      <div class="flex items-center gap-4 mb-8">
        <div class="flex-1 h-px bg-gold/40"></div>
        <span class="font-serif text-gold text-xl">&#10022;</span>
        <div class="flex-1 h-px bg-gold/40"></div>
      </div>

      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">

        <!-- Left 55% — text -->
        <div class="lg:w-[55%] animate-on-scroll">
          <!-- Gold ornament rule -->
          <div class="flex items-center gap-3 mb-5">
            <div class="w-12 h-0.5 bg-gold"></div>
            <span class="font-sans text-xs tracking-[0.2em] uppercase text-gold font-semibold">Established 1992</span>
            <div class="flex-1 h-0.5 bg-gold/30"></div>
          </div>

          <h1 class="font-serif font-black text-navy leading-tight mb-5"
              style="font-size: clamp(2.6rem, 6vw, 4.8rem);">
            Naperville's Most<br/>
            Trusted Family
          </h1>

          <p class="font-sans text-navy/70 text-lg leading-relaxed mb-6">
            Mike &amp; Kathy Petersen have been helping families find home since 1992.
            Now their children carry on the tradition.
          </p>

          <!-- Since 1992 badge + stats -->
          <div class="flex flex-wrap items-center gap-6 mb-8">
            <!-- Badge -->
            <div class="flex-shrink-0 w-20 h-20 rounded-full bg-navy flex flex-col items-center justify-center border-2 border-gold">
              <span class="font-sans text-[9px] tracking-widest uppercase text-gold font-bold">Since</span>
              <span class="font-serif text-gold text-xl font-bold leading-none">1992</span>
              <span class="font-sans text-[9px] tracking-widest uppercase text-gold/70 font-bold">32 Years</span>
            </div>
            <!-- Stat -->
            <div>
              <p class="font-serif text-4xl font-bold text-navy leading-none">1,200<span class="text-gold">+</span></p>
              <p class="font-sans text-sm text-navy/60 uppercase tracking-widest mt-1">Families helped</p>
            </div>
          </div>

          <!-- CTAs -->
          <div class="flex flex-wrap gap-4">
            <a href="#listings"
               class="bg-navy text-white font-sans font-bold px-8 py-3 hover:bg-navy-mid transition-colors tracking-wide">
              View Our Listings
            </a>
            <a href="#about"
               class="font-serif italic text-gold text-lg underline underline-offset-4 hover:text-gold-light transition-colors self-center">
              Our Story &rarr;
            </a>
          </div>
        </div>

        <!-- Right 45% — framed photo -->
        <div class="lg:w-[45%] flex-shrink-0 flex justify-center animate-on-scroll" style="animation-delay:0.2s">
          <!-- Offset shadow then frame -->
          <div class="relative" style="max-width: 420px; width: 100%;">
            <div class="absolute inset-0 bg-navy translate-x-4 translate-y-4"></div>
            <div class="relative border-4 border-navy bg-white p-3"
                 style="box-shadow: 2px 2px 20px rgba(0,0,0,0.2);">
              <img
                src="https://images.unsplash.com/photo-1560184897-ae75f418493e?w=900&q=85"
                alt="Beautiful Naperville suburban home"
                class="w-full object-cover"
                style="height: 320px;"
                loading="eager"
              />
            </div>
          </div>
        </div>

      </div>

      <!-- Bottom decorative rule -->
      <div class="flex items-center gap-4 mt-12">
        <div class="flex-1 h-px bg-gold/40"></div>
        <span class="font-serif text-gold text-xl">&#10022;</span>
        <div class="flex-1 h-px bg-gold/40"></div>
      </div>

    </div>
  </section>

  <!-- ============================================================
       3. TRUST STRIP
  ============================================================ -->
  <section class="bg-beige-dark py-10 border-y border-beige-deep">
    <div class="max-w-5xl mx-auto px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        {[
          { icon: '🏆', stat: '32 Years', label: 'Experience' },
          { icon: '👨‍👩‍👧‍👦', stat: '1,200+', label: 'Families Served' },
          { icon: '📍', stat: 'Naperville', label: 'Since 1992' },
          { icon: '⭐', stat: '4.9★', label: 'Avg Rating' },
        ].map(item => (
          <div class="animate-on-scroll">
            <div class="text-3xl mb-2">{item.icon}</div>
            <div class="font-serif font-bold text-navy text-2xl">{item.stat}</div>
            <div class="font-sans text-xs uppercase tracking-widest text-navy/50 mt-1">{item.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       4. FEATURED LISTINGS — SCRAPBOOK CARDS
  ============================================================ -->
  <section id="listings" class="py-16 md:py-24 bg-white">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">

      <!-- Section heading with decorative rule -->
      <div class="text-center mb-14 animate-on-scroll">
        <h2 class="font-serif font-bold text-navy text-4xl mb-3">Featured Homes</h2>
        <div class="flex items-center justify-center gap-4">
          <div class="w-16 h-0.5 bg-gold"></div>
          <span class="font-serif text-gold text-xl">&#10022;</span>
          <div class="w-16 h-0.5 bg-gold"></div>
        </div>
      </div>

      <!-- 3-col grid (4th card spans wider on mobile) -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {listings.map((listing, i) => (
          <div
            class="bg-white border border-beige-dark animate-on-scroll cursor-pointer group"
            style={`transform: rotate(${listing.rotate}); animation-delay: ${i * 0.1}s; box-shadow: 2px 4px 16px rgba(0,0,0,0.07);`}
          >
            <!-- Image with photo-frame border -->
            <div class="p-3 bg-beige">
              <div class="relative overflow-hidden border-2 border-navy/10" style="padding-top: 66%;">
                <img
                  src={listing.image}
                  alt={listing.address}
                  class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
                <!-- Status badge -->
                <span class="absolute top-3 left-3 bg-navy text-white font-sans text-[10px] font-bold px-3 py-1 tracking-widest uppercase">
                  {listing.status}
                </span>
              </div>
            </div>

            <!-- Card body -->
            <div class="p-5">
              <p class="font-serif font-bold text-navy text-2xl mb-1">{listing.price}</p>
              <p class="font-sans text-navy text-sm font-semibold mb-0.5">{listing.address}</p>
              <p class="font-sans text-navy/50 text-sm mb-3">{listing.city}, IL &nbsp;&middot;&nbsp; {listing.beds} bd / {listing.baths} ba</p>
              <a href="#contact"
                 class="block w-full text-center bg-navy text-white font-sans text-sm font-bold py-2.5 hover:bg-navy-mid transition-colors tracking-wide">
                Schedule a Showing
              </a>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ============================================================
       5. NEIGHBORHOODS + SVG MAP
  ============================================================ -->
  <section id="neighborhoods" class="py-16 md:py-24 bg-beige">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">

      <div class="text-center mb-12 animate-on-scroll">
        <h2 class="font-serif font-bold text-navy text-4xl mb-3">The Communities We Serve</h2>
        <div class="flex items-center justify-center gap-4">
          <div class="w-16 h-0.5 bg-gold"></div>
          <span class="font-sans text-gold text-xs tracking-widest uppercase font-bold">Western Suburbs</span>
          <div class="w-16 h-0.5 bg-gold"></div>
        </div>
      </div>

      <!-- 4 neighborhood photo tiles -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-14">
        {neighborhoods.map((n, i) => (
          <div class="group cursor-pointer animate-on-scroll" style={`animation-delay: ${i * 0.1}s`}>
            <div class="relative overflow-hidden border-2 border-navy/10" style="padding-top: 80%;">
              <img
                src={n.photo}
                alt={n.name}
                class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-navy/40 group-hover:bg-navy/30 transition-colors"></div>
              <div class="absolute bottom-0 left-0 right-0 p-3">
                <p class="font-serif font-bold text-white text-lg leading-tight">{n.name}</p>
                <a href="#contact" class="font-sans text-gold text-xs underline">{n.listings} active listings</a>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- SVG Map illustration -->
      <div class="max-w-3xl mx-auto animate-on-scroll" style="animation-delay: 0.2s">
        <div class="border-2 border-navy bg-white p-4 shadow-md"
             style="box-shadow: 4px 4px 0 #1B3A5C;">
          <p class="font-serif text-center text-navy text-sm font-bold mb-3 tracking-wide uppercase">
            The Petersen Group — Service Area
          </p>
          <svg viewBox="0 0 560 380" xmlns="http://www.w3.org/2000/svg" class="w-full" aria-label="Map of western Chicago suburbs served by The Petersen Group">
            <!-- Background -->
            <rect width="560" height="380" fill="#FDFAF5"/>

            <!-- DuPage River (hand-drawn style) -->
            <path d="M220 370 Q225 320 218 270 Q212 225 222 185 Q230 155 224 110 Q218 80 228 50"
                  stroke="#A8C8DC" stroke-width="4" fill="none" stroke-linecap="round"
                  opacity="0.7"/>

            <!-- Area fills (rough polygons, slightly imperfect) -->
            <!-- Aurora (west) -->
            <polygon points="30,220 95,190 108,240 105,295 42,305"
                     fill="#EAE3D6" stroke="#1B3A5C" stroke-width="1.5" opacity="0.6"/>
            <!-- Naperville (center — larger, shaded darker as home base) -->
            <polygon points="118,155 205,142 228,185 238,255 212,300 162,310 128,275 108,215"
                     fill="#D9CEBD" stroke="#1B3A5C" stroke-width="2.5" opacity="0.9"/>
            <!-- Wheaton (north) -->
            <polygon points="195,60 285,50 295,105 262,140 205,142 178,115"
                     fill="#EAE3D6" stroke="#1B3A5C" stroke-width="1.5" opacity="0.65"/>
            <!-- Downers Grove (east) -->
            <polygon points="268,140 360,128 375,195 335,228 262,218 238,185"
                     fill="#EAE3D6" stroke="#1B3A5C" stroke-width="1.5" opacity="0.65"/>
            <!-- Lisle (south-east of Naperville) -->
            <polygon points="238,255 320,240 338,295 295,325 228,315 212,300"
                     fill="#EAE3D6" stroke="#1B3A5C" stroke-width="1.5" opacity="0.65"/>
            <!-- Bolingbrook (south) -->
            <polygon points="118,300 175,300 185,350 145,370 90,355 95,320"
                     fill="#EAE3D6" stroke="#1B3A5C" stroke-width="1.5" opacity="0.6"/>

            <!-- Roads: I-88 (E-W) and Route 53 (N-S) -->
            <line x1="0" y1="222" x2="560" y2="222" stroke="#C49A3C" stroke-width="1.5" stroke-dasharray="8 4" opacity="0.5"/>
            <text x="8" y="217" font-family="Georgia,serif" font-size="9" fill="#8B7355" opacity="0.8">I-88</text>
            <line x1="240" y1="0" x2="240" y2="380" stroke="#C49A3C" stroke-width="1.5" stroke-dasharray="8 4" opacity="0.5"/>
            <text x="244" y="12" font-family="Georgia,serif" font-size="9" fill="#8B7355" opacity="0.8">Rte 53</text>

            <!-- City markers: outer glow + pin dot + gold center -->
            <!-- Naperville -->
            <circle cx="178" cy="228" r="12" fill="#1B3A5C" opacity="0.12"/>
            <circle cx="178" cy="228" r="6" fill="#1B3A5C"/>
            <circle cx="178" cy="228" r="2.5" fill="#C49A3C"/>
            <text x="192" y="224" font-family="Georgia,serif" font-size="13" font-weight="bold" fill="#1B3A5C">Naperville</text>
            <text x="192" y="238" font-family="Georgia,serif" font-size="9" fill="#8B7355" font-style="italic">home base since 1992</text>

            <!-- Wheaton -->
            <circle cx="240" cy="100" r="9" fill="#1B3A5C" opacity="0.12"/>
            <circle cx="240" cy="100" r="5" fill="#1B3A5C"/>
            <circle cx="240" cy="100" r="2" fill="#C49A3C"/>
            <text x="252" y="97" font-family="Georgia,serif" font-size="12" font-weight="bold" fill="#1B3A5C">Wheaton</text>
            <text x="252" y="109" font-family="Georgia,serif" font-size="9" fill="#8B7355">4 listings</text>

            <!-- Downers Grove -->
            <circle cx="310" cy="178" r="9" fill="#1B3A5C" opacity="0.12"/>
            <circle cx="310" cy="178" r="5" fill="#1B3A5C"/>
            <circle cx="310" cy="178" r="2" fill="#C49A3C"/>
            <text x="322" y="175" font-family="Georgia,serif" font-size="12" font-weight="bold" fill="#1B3A5C">Downers Grove</text>
            <text x="322" y="187" font-family="Georgia,serif" font-size="9" fill="#8B7355">3 listings</text>

            <!-- Lisle -->
            <circle cx="278" cy="282" r="9" fill="#1B3A5C" opacity="0.12"/>
            <circle cx="278" cy="282" r="5" fill="#1B3A5C"/>
            <circle cx="278" cy="282" r="2" fill="#C49A3C"/>
            <text x="290" y="279" font-family="Georgia,serif" font-size="12" font-weight="bold" fill="#1B3A5C">Lisle</text>
            <text x="290" y="291" font-family="Georgia,serif" font-size="9" fill="#8B7355">2 listings</text>

            <!-- Aurora -->
            <circle cx="66" cy="252" r="9" fill="#1B3A5C" opacity="0.12"/>
            <circle cx="66" cy="252" r="5" fill="#1B3A5C"/>
            <circle cx="66" cy="252" r="2" fill="#C49A3C"/>
            <text x="18" y="270" font-family="Georgia,serif" font-size="12" font-weight="bold" fill="#1B3A5C">Aurora</text>

            <!-- Bolingbrook -->
            <circle cx="138" cy="330" r="9" fill="#1B3A5C" opacity="0.12"/>
            <circle cx="138" cy="330" r="5" fill="#1B3A5C"/>
            <circle cx="138" cy="330" r="2" fill="#C49A3C"/>
            <text x="150" y="327" font-family="Georgia,serif" font-size="12" font-weight="bold" fill="#1B3A5C">Bolingbrook</text>

            <!-- Compass -->
            <text x="520" y="355" font-family="Georgia,serif" font-size="11" fill="#1B3A5C" text-anchor="middle" font-style="italic">N ↑</text>
            <line x1="520" y1="360" x2="520" y2="370" stroke="#1B3A5C" stroke-width="1"/>

            <!-- Legend -->
            <rect x="15" y="355" width="8" height="8" fill="#D9CEBD" stroke="#1B3A5C" stroke-width="1"/>
            <text x="28" y="363" font-family="Georgia,serif" font-size="8" fill="#8B7355">Service area</text>
            <circle cx="95" cy="359" r="4" fill="#1B3A5C"/>
            <circle cx="95" cy="359" r="1.5" fill="#C49A3C"/>
            <text x="105" y="363" font-family="Georgia,serif" font-size="8" fill="#8B7355">City marker</text>
          </svg>
        </div>
      </div>

    </div>
  </section>

  <!-- ============================================================
       6. ABOUT / MEET THE TEAM — SCRAPBOOK COLLAGE
  ============================================================ -->
  <section id="about" class="py-16 md:py-24 bg-beige">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">

      <!-- Section heading with gold ornament -->
      <div class="text-center mb-12 animate-on-scroll">
        <span class="font-serif text-gold text-3xl block mb-2">&#10022;</span>
        <h2 class="font-serif font-bold text-navy text-4xl mb-3">Meet the Petersens</h2>
        <p class="font-sans text-navy/60 text-lg italic">A family business. A neighborhood tradition.</p>
      </div>

      <div class="flex flex-col lg:flex-row gap-14 items-start">

        <!-- Left: Overlapping collage -->
